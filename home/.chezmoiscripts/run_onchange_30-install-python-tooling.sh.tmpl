#!/usr/bin/env bash
set -eo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
fi

log() { printf '%b[python-tooling]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[python-tooling]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
ok() { printf '%b[python-tooling]%b %s\n' "$c_green" "$c_reset" "$*"; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }
can_sudo() { sudo -n true >/dev/null 2>&1; }
is_arch() { has_cmd pacman; }

# On Arch Linux, pip and pipx have different package names (python-pip, python-pipx).
# This function maps generic names to their Arch equivalents.
arch_pkg_name() {
  local pkg="$1"
  if is_arch; then
    case "$pkg" in
      python3) echo "python" ;;      # Arch packages Python as 'python', not 'python3'
      pip)     echo "python-pip" ;;
      pipx)    echo "python-pipx" ;;
      *)       echo "$pkg" ;;
    esac
  else
    echo "$pkg"
  fi
}

install_uv() {
  # uv is not in apt/dnf repos — always install via curl (astral.sh installer)
  if has_cmd uv; then
    ok "uv already installed: $(uv --version 2>&1)"
    return 0
  fi
  log "installing uv via curl..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  # Ensure uv is on PATH for the rest of this script
  if [[ -d "$HOME/.local/bin" ]] && ! echo "$PATH" | grep -q "$HOME/.local/bin"; then
    export PATH="$HOME/.local/bin:$PATH"
  fi
  if [[ -d "$HOME/.cargo/bin" ]] && ! echo "$PATH" | grep -q "$HOME/.cargo/bin"; then
    export PATH="$HOME/.cargo/bin:$PATH"
  fi
  if has_cmd uv; then
    ok "uv installed: $(uv --version 2>&1)"
  else
    warn "uv installer ran but uv not found in PATH — restart your shell"
  fi
}

install_pkg() {
  local pkg
  pkg="$(arch_pkg_name "$1")"

  # uv is not in system package repos — delegate to its own installer
  if [[ "$1" == "uv" ]]; then
    install_uv
    return 0
  fi

  # Resolve the command name to check: python3 package exposes 'python3' binary
  local cmd="$1"
  # On modern Debian/Ubuntu, the package is 'python3' but the check command is also 'python3'
  # On Arch, the package is 'python' but the command is 'python3'
  if [[ "$cmd" == "python3" ]]; then
    has_cmd python3 && ok "already installed: python3" && return 0
  elif has_cmd "$cmd"; then
    ok "already installed: $cmd"
    return 0
  fi

  if is_arch; then
    if can_sudo; then sudo pacman -S --noconfirm --needed "$pkg"; else warn "skip $pkg (sudo unavailable)"; fi
  elif has_cmd apt-get; then
    if can_sudo; then sudo apt-get update -y && sudo apt-get install -y "$pkg"; else warn "skip $pkg (sudo unavailable)"; fi
  elif has_cmd dnf; then
    if can_sudo; then sudo dnf install -y "$pkg"; else warn "skip $pkg (sudo unavailable)"; fi
  elif has_cmd brew; then
    brew install "$pkg"
  else
    warn "unsupported OS package manager for $pkg"
  fi
}

{{- range .groups.python }}
install_pkg "{{ . }}"
{{- end }}

# Ensure pipx bin dir is on PATH
if has_cmd pipx; then
  pipx ensurepath --force >/dev/null 2>&1 || true
  ok "pipx ensurepath done"
fi
