#!/usr/bin/env bash
# chezmoi:template:left-delimiter="{{" right-delimiter="}}"
set -eo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
fi

log() { printf '%b[dots-agents]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[dots-agents]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
ok() { printf '%b[dots-agents]%b %s\n' "$c_green" "$c_reset" "$*"; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }
can_sudo() { sudo -n true >/dev/null 2>&1; }

is_arch()   { has_cmd pacman; }
is_macos()  { [[ "$(uname -s)" == "Darwin" ]]; }
has_brew()  { has_cmd brew; }
has_npm()   { has_cmd npm; }
has_go()    { has_cmd go; }

is_official_slack_cli() {
  (has_cmd slack && slack --help 2>/dev/null | grep -q "create, run, and deploy Slack apps") || \
    (has_cmd slack-dev && slack-dev --help 2>/dev/null | grep -q "create, run, and deploy Slack apps")
}

aur_install() {
  local pkg="$1"
  if has_cmd paru; then
    paru -S --noconfirm --needed "$pkg"
  elif has_cmd yay; then
    yay -S --noconfirm --needed "$pkg"
  else
    warn "AUR helper (paru/yay) not found; cannot install $pkg via AUR"
    return 1
  fi
}

# Install a Python CLI tool via uv tool, pipx, or pip (in that order).
# Usage: install_python_tool <pkg>
install_python_tool() {
  local pkg="$1"
  if has_cmd uv; then
    if uv tool list 2>/dev/null | grep -q "^${pkg} "; then
      ok "${pkg} already installed (uv tool)"
    else
      uv tool install "$pkg" && ok "${pkg} installed via uv tool" || warn "uv tool install ${pkg} failed"
    fi
  elif has_cmd pipx; then
    if pipx list --short 2>/dev/null | grep -q "^${pkg} "; then
      ok "${pkg} already installed (pipx)"
    else
      pipx install "$pkg" && ok "${pkg} installed via pipx" || warn "pipx install ${pkg} failed"
    fi
  elif has_cmd pip3; then
    pip3 install --user --quiet "$pkg" && ok "${pkg} installed via pip3" || warn "pip3 install ${pkg} failed"
  elif has_cmd pip; then
    pip install --user --quiet "$pkg" && ok "${pkg} installed via pip" || warn "pip install ${pkg} failed"
  else
    warn "uv/pipx/pip3/pip not found — cannot install ${pkg}. Install uv first."
  fi
}

# ---------------------------------------------------------------------------
# clickup CLI (always installed)
# ---------------------------------------------------------------------------
log "checking clickup CLI..."
if has_cmd clickup; then
  ok "clickup already installed: $(clickup version 2>/dev/null || echo 'unknown')"
else
  # Prefer Go over brew for version pinning (brew installs latest which may be broken)
  if has_go; then
    log "installing clickup via go install..."
    # Pin to v0.20.0 - v0.21.0 has breaking API changes (undefined: apiv2.UpdateTask)
    go install github.com/triptechtravel/clickup-cli/cmd/clickup@v0.20.0
  elif has_brew; then
    log "installing clickup via brew..."
    brew install triptechtravel/tap/clickup
  else
    warn "neither brew nor go found; skipping clickup install"
  fi
fi

# ---------------------------------------------------------------------------
# Official Slack CLI (Slack Developer Platform)
# Docs: https://docs.slack.dev/tools/slack-cli/
# ---------------------------------------------------------------------------
log "checking official Slack CLI..."
if is_official_slack_cli; then
  ok "official Slack CLI already installed"
else
  if has_cmd slack; then
    log "detected a non-official 'slack' binary; installing official Slack CLI as alias 'slack-dev'..."
    curl -fsSL https://downloads.slack-edge.com/slack-cli/install.sh | bash -s -- slack-dev
    if has_cmd slack-dev; then
      log "official Slack CLI installed as: slack-dev"
    else
      warn "slack-dev alias installation did not expose command in PATH yet"
    fi
  else
    log "installing official Slack CLI..."
    curl -fsSL https://downloads.slack-edge.com/slack-cli/install.sh | bash
    if is_official_slack_cli; then
      log "official Slack CLI installed as: slack"
    else
      warn "Slack CLI installed but may require new shell for PATH refresh"
    fi
  fi
fi

# ---------------------------------------------------------------------------
# rtk — CLI output compression proxy (always installed)
# ---------------------------------------------------------------------------
log "checking rtk..."
if has_cmd rtk; then
  ok "rtk already installed"
else
  if is_arch; then
    log "installing rtk via AUR..."
    aur_install rtk-bin || {
      log "AUR install failed; falling back to curl install"
      curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh
    }
  elif has_brew; then
    log "installing rtk via brew..."
    brew install rtk
  else
    log "installing rtk via curl..."
    curl -fsSL https://raw.githubusercontent.com/rtk-ai/rtk/refs/heads/master/install.sh | sh
  fi
fi

# ---------------------------------------------------------------------------
# uipro CLI - UI/UX Pro Max installer (opt-in)
# ---------------------------------------------------------------------------
log "checking uipro CLI..."
if has_cmd uipro; then
  ok "uipro already installed: $(uipro --version 2>/dev/null || echo 'unknown')"
else
  if has_npm; then
    log "installing uipro-cli via npm..."
    npm install -g uipro-cli
  else
    warn "npm not found; skipping uipro-cli install (install Node via fnm first)"
  fi
fi

# ---------------------------------------------------------------------------
# claude-code (opt-in)
# ---------------------------------------------------------------------------
{{- if (index . "install_agent_claude_code" | default false) }}
log "checking claude-code..."
if has_cmd claude; then
  ok "claude-code already installed"
else
  if has_npm; then
    log "installing claude-code via npm..."
    npm install -g @anthropic-ai/claude-code
  else
    warn "npm not found; skipping claude-code install (install Node via fnm first)"
  fi
fi
{{- end }}

# ---------------------------------------------------------------------------
# opencode (opt-in)
# ---------------------------------------------------------------------------
{{- if (index . "install_agent_opencode" | default false) }}
log "checking opencode..."
if has_cmd opencode; then
  ok "opencode already installed"
else
  if is_arch; then
    if has_cmd pacman && can_sudo; then
      log "installing opencode via pacman..."
      sudo pacman -S --noconfirm --needed opencode 2>/dev/null || aur_install opencode-bin
    else
      aur_install opencode-bin
    fi
  elif has_brew; then
    log "installing opencode via brew..."
    brew install opencode
  else
    log "installing opencode via curl..."
    curl -fsSL https://opencode.ai/install | bash
  fi
fi
{{- end }}

# ---------------------------------------------------------------------------
# pi coding agent (opt-in)
# ---------------------------------------------------------------------------
{{- if (index . "install_agent_pi" | default false) }}
log "checking pi coding agent..."
if has_cmd pi; then
  ok "pi already installed"
else
  if is_macos && has_brew; then
    log "installing pi via brew..."
    brew install pi-coding-agent
  elif is_arch; then
    log "installing pi via AUR..."
    aur_install pi-coding-agent || {
      log "AUR install failed; falling back to npm"
      npm install -g @mariozechner/pi-coding-agent
    }
  elif has_npm; then
    log "installing pi via npm..."
    npm install -g @mariozechner/pi-coding-agent
  else
    warn "no suitable installer found for pi; install Node via fnm first"
  fi
fi
{{- end }}

# ---------------------------------------------------------------------------
# GitHub Copilot CLI extension (opt-in, requires gh auth)
# ---------------------------------------------------------------------------
{{- if (index . "install_agent_copilot_cli" | default false) }}
log "checking GitHub Copilot CLI..."
if has_cmd gh && gh extension list 2>/dev/null | grep -q "github/gh-copilot"; then
  ok "gh-copilot extension already installed"
elif has_cmd gh; then
  log "installing gh-copilot extension..."
  gh extension install github/gh-copilot || warn "gh-copilot install failed (ensure gh is authenticated)"
else
  warn "gh CLI not found; skipping copilot-cli install"
fi
{{- end }}

# ---------------------------------------------------------------------------
# Prerequisite verification — ensure uv and node are available
# ---------------------------------------------------------------------------
log "verifying prerequisites for AI tooling..."
if ! has_cmd uv; then
  warn "uv is required for AI tooling but not found in PATH"
  warn "The python-baseline script should have installed it — check for errors above"
  warn "Attempting to install uv now..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  if [[ -d "$HOME/.local/bin" ]] && ! echo "$PATH" | grep -q "$HOME/.local/bin"; then
    export PATH="$HOME/.local/bin:$PATH"
  fi
  if has_cmd uv; then
    ok "uv installed on-demand: $(uv --version 2>&1)"
  else
    warn "uv still not available — some Python CLI tools may fail to install"
  fi
else
  ok "uv verified: $(uv --version 2>&1)"
fi

if ! has_cmd node; then
  warn "node is required for AI tooling but not found in PATH"
  warn "The node-baseline script should have installed it — check for errors above"
  if has_cmd fnm; then
    warn "fnm found, attempting to install Node.js LTS..."
    fnm install --lts 2>/dev/null || true
    fnm default lts-latest 2>/dev/null || true
    eval "$(fnm env --use-on-cd 2>/dev/null)" || true
    if has_cmd node; then
      ok "node installed on-demand: $(node --version 2>&1)"
    else
      warn "node still not available — some Node CLI tools may fail to install"
    fi
  else
    warn "fnm not found — cannot install node on-demand"
  fi
else
  ok "node verified: $(node --version 2>&1)"
fi

# ---------------------------------------------------------------------------
# Python CLI tools for external skills
# ---------------------------------------------------------------------------
log "installing JIRA Assistant Skills CLI (jira-as)..."
install_python_tool "jira-as"
log "installing Confluence Assistant Skills CLI (confluence-as)..."
install_python_tool "confluence-as"

# ---------------------------------------------------------------------------
# Confluence CLI compatibility wrapper
# The external confluence skill pack references `confluence` but the actual
# binary is `confluence-as`. Create a symlink so agents find it either way.
# ---------------------------------------------------------------------------
if has_cmd confluence-as && ! has_cmd confluence; then
  local_bin="{{ .chezmoi.homeDir }}/.local/bin"
  mkdir -p "$local_bin"
  ln -sf "$(which confluence-as)" "$local_bin/confluence"
  ok "created confluence → confluence-as wrapper for skill compatibility"
fi

# ---------------------------------------------------------------------------
# Skills sync — regenerate AI tool symlinks based on skill.json compatibility
# ---------------------------------------------------------------------------
log "syncing skills across AI tools..."
if command -v dots-skills &>/dev/null; then
  dots-skills sync
else
  warn "dots-skills not found in PATH; skipping skills sync"
  warn "Run 'chezmoi apply' again after the workstation is fully bootstrapped"
fi

log "ai-agents setup complete"
