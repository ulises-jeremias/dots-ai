#!/usr/bin/env bash
set -euo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
fi

log() { printf '%b[ai-tooling]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[ai-tooling]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }

log "No optional AI packages configured"
