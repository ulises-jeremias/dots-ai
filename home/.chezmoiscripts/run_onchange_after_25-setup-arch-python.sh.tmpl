#!/usr/bin/env bash
# run_onchange_after_25-setup-arch-python.sh.tmpl
# hash: {{ include (joinPath .chezmoi.sourceDir "dot_local/share/dots-ai/pacman-hooks/pipx-reinstall.hook") | sha256sum }}
{{- $gPy := index . "install_group_python" | default false -}}
{{- $gAi := index . "install_group_ai"     | default false -}}
{{- $gSkJ := index . "install_skill_jira_assistant"       | default false -}}
{{- $gSkC := index . "install_skill_confluence_assistant" | default false -}}
{{- if or $gPy $gAi $gSkJ $gSkC -}}
set -eo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
  c_red=$'\033[1;31m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
  c_red=''
fi

log()  { printf '%b[arch-python]%b %s\n' "$c_blue"   "$c_reset" "$*"; }
ok()   { printf '  %b✓%b %s\n'           "$c_green"  "$c_reset" "$*"; }
warn() { printf '  %b!%b %s\n'           "$c_yellow" "$c_reset" "$*"; }
fail() { printf '  %b✗%b %s\n'           "$c_red"    "$c_reset" "$*"; }

has_cmd() { command -v "$1" >/dev/null 2>&1; }
can_sudo() { sudo -n true >/dev/null 2>&1; }

# Only run on Arch Linux
if ! has_cmd pacman; then
  log "not Arch Linux — skipping"
  exit 0
fi

log "configuring Python environment for Arch Linux..."

# ── 1. Install pacman hook for auto-reinstalling pipx after Python upgrades ──

HOOK_SRC="{{ .chezmoi.homeDir }}/.local/share/dots-ai/pacman-hooks/pipx-reinstall.hook"
HOOK_DIR="/etc/pacman.d/hooks"
HOOK_DST="${HOOK_DIR}/pipx-reinstall.hook"

if [[ ! -f "$HOOK_SRC" ]]; then
  warn "hook source not found at ${HOOK_SRC} — skipping pacman hook install"
else
  if ! can_sudo; then
    warn "sudo unavailable — cannot install pacman hook (run manually: sudo cp ${HOOK_SRC} ${HOOK_DST})"
  else
    sudo mkdir -p "$HOOK_DIR"
    if [[ -f "$HOOK_DST" ]] && diff -q "$HOOK_SRC" "$HOOK_DST" >/dev/null 2>&1; then
      ok "pacman hook already up to date: ${HOOK_DST}"
    else
      sudo cp "$HOOK_SRC" "$HOOK_DST"
      ok "pacman hook installed: ${HOOK_DST}"
    fi
  fi
fi

# ── 2. Ensure pipx bin dir exists and is on PATH ──────────────────────────────

if has_cmd pipx; then
  pipx ensurepath --force >/dev/null 2>&1 || true
  ok "pipx ensurepath done"
else
  warn "pipx not found — install python-pipx via pacman first"
fi

# ── 3. Reinstall pipx packages if Python was just upgraded ────────────────────
# This is a safety net in case the pacman hook didn't run (e.g. first install).

if has_cmd pipx; then
  PIPX_LIST="$(pipx list --short 2>/dev/null || true)"
  if [[ -n "$PIPX_LIST" ]]; then
    log "verifying pipx packages are compatible with current Python..."
    if pipx reinstall-all --python /usr/bin/python3 >/dev/null 2>&1; then
      ok "pipx packages verified/reinstalled"
    else
      warn "pipx reinstall-all failed — run manually: pipx reinstall-all"
    fi
  else
    ok "no pipx packages installed yet"
  fi
fi

log "Arch Linux Python setup complete"
{{ end -}}
