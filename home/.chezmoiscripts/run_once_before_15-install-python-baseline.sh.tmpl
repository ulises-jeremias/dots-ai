#!/usr/bin/env bash
# chezmoi:template:left-delimiter="{{" right-delimiter="}}"
#
# Python baseline — installed when the python group is enabled OR when
# AI/skill features that need a Python runtime are enabled (jira-as,
# confluence-as and many AI tool CLIs). Guarded at template render time.
{{- $gPy := index . "install_group_python" | default false -}}
{{- $gAi := index . "install_group_ai"     | default false -}}
{{- $gSkJ := index . "install_skill_jira_assistant"       | default false -}}
{{- $gSkC := index . "install_skill_confluence_assistant" | default false -}}
{{- if or $gPy $gAi $gSkJ $gSkC -}}
set -eo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
fi

log() { printf '%b[python-baseline]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[python-baseline]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
ok() { printf '%b[python-baseline]%b %s\n' "$c_green" "$c_reset" "$*"; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }
can_sudo() { sudo -n true >/dev/null 2>&1; }
is_arch() { has_cmd pacman; }
has_brew() { has_cmd brew; }

# ---------------------------------------------------------------------------
# Install python3 if missing
# ---------------------------------------------------------------------------
if ! has_cmd python3; then
  log "installing python3..."
  if is_arch; then
    if can_sudo; then sudo pacman -S --noconfirm --needed python; else warn "skip python (sudo unavailable)"; fi
  elif has_cmd apt-get; then
    if can_sudo; then sudo apt-get update -y && sudo apt-get install -y python3; else warn "skip python3 (sudo unavailable)"; fi
  elif has_cmd dnf; then
    if can_sudo; then sudo dnf install -y python3; else warn "skip python3 (sudo unavailable)"; fi
  elif has_brew; then
    brew install python
  else
    warn "unsupported OS — cannot install python3 automatically"
  fi
else
  ok "python3 already installed: $(python3 --version 2>&1)"
fi

# ---------------------------------------------------------------------------
# Install uv if missing (fast Python tool installer)
# ---------------------------------------------------------------------------
if ! has_cmd uv; then
  log "installing uv..."
  curl -LsSf https://astral.sh/uv/install.sh | sh
  if [[ -d "$HOME/.local/bin" ]] && ! echo "$PATH" | grep -q "$HOME/.local/bin"; then
    export PATH="$HOME/.local/bin:$PATH"
  fi
  if [[ -d "$HOME/.cargo/bin" ]] && ! echo "$PATH" | grep -q "$HOME/.cargo/bin"; then
    export PATH="$HOME/.cargo/bin:$PATH"
  fi
  if has_cmd uv; then
    ok "uv installed: $(uv --version 2>&1)"
  else
    warn "uv installer ran but uv not found in PATH — restart your shell"
  fi
else
  ok "uv already installed: $(uv --version 2>&1)"
fi

# ---------------------------------------------------------------------------
# Ensure pipx is available as fallback
# ---------------------------------------------------------------------------
if ! has_cmd pipx; then
  log "installing pipx as fallback..."
  if is_arch; then
    if can_sudo; then sudo pacman -S --noconfirm --needed python-pipx; else warn "skip pipx (sudo unavailable)"; fi
  elif has_cmd apt-get; then
    if can_sudo; then sudo apt-get install -y pipx; else warn "skip pipx (sudo unavailable)"; fi
  elif has_cmd dnf; then
    if can_sudo; then sudo dnf install -y pipx; else warn "skip pipx (sudo unavailable)"; fi
  elif has_brew; then
    brew install pipx
  elif has_cmd uv; then
    uv tool install pipx 2>/dev/null || warn "could not install pipx via uv"
  else
    warn "no package manager available for pipx"
  fi
else
  ok "pipx already installed"
fi

if has_cmd pipx; then
  pipx ensurepath --force >/dev/null 2>&1 || true
fi

log "python baseline complete"
{{ end -}}
