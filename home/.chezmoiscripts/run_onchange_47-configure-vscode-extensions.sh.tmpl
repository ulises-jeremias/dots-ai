#!/usr/bin/env bash
# VSCode extensions — rendered only when VSCode editor is enabled AND at
# least one extension flag is true. If none are enabled the script is a
# no-op shebang.
{{- $eVs  := index . "install_editor_vscode"            | default false -}}
{{- $x1   := index . "install_vscode_ext_gitlens"       | default false -}}
{{- $x2   := index . "install_vscode_ext_editorconfig"  | default false -}}
{{- $x3   := index . "install_vscode_ext_copilot"       | default false -}}
{{- $x4   := index . "install_vscode_ext_copilot_chat"  | default false -}}
{{- $x5   := index . "install_vscode_ext_python"        | default false -}}
{{- $x6   := index . "install_vscode_ext_yaml"          | default false -}}
{{- $x7   := index . "install_vscode_ext_spellcheck"    | default false -}}
{{- $x8   := index . "install_vscode_ext_markdown"      | default false -}}
{{- $x9   := index . "install_vscode_ext_claude_code"   | default false -}}
{{- $anyExt := or $x1 $x2 $x3 $x4 $x5 $x6 $x7 $x8 $x9 -}}
{{- if and $eVs $anyExt -}}
set -euo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
fi

log() { printf '%b[vscode-ext]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[vscode-ext]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
ok() { printf '%b[vscode-ext]%b %s\n' "$c_green" "$c_reset" "$*"; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }

selected_extension_count=0

ensure_extension() {
  local ext="$1"
  selected_extension_count=$((selected_extension_count + 1))
  if code --list-extensions 2>/dev/null | grep -iq "^${ext}$"; then
    ok "already installed: $ext"
    return 0
  fi
  if code --force --install-extension "$ext"; then
    ok "installed: $ext"
  else
    warn "failed to install extension: $ext"
  fi
}

if ! has_cmd code; then
  log "VSCode CLI (code) not found; skipping extension setup"
  exit 0
fi

{{- if (index . "install_vscode_ext_gitlens" | default false) }}
ensure_extension "eamodio.gitlens"
{{- end }}
{{- if (index . "install_vscode_ext_editorconfig" | default false) }}
ensure_extension "EditorConfig.EditorConfig"
{{- end }}
{{- if (index . "install_vscode_ext_copilot" | default false) }}
ensure_extension "github.copilot"
{{- end }}
{{- if (index . "install_vscode_ext_copilot_chat" | default false) }}
ensure_extension "github.copilot-chat"
{{- end }}
{{- if (index . "install_vscode_ext_python" | default false) }}
ensure_extension "ms-python.python"
{{- end }}
{{- if (index . "install_vscode_ext_yaml" | default false) }}
ensure_extension "redhat.vscode-yaml"
{{- end }}
{{- if (index . "install_vscode_ext_spellcheck" | default false) }}
ensure_extension "streetsidesoftware.code-spell-checker"
{{- end }}
{{- if (index . "install_vscode_ext_markdown" | default false) }}
ensure_extension "yzhang.markdown-all-in-one"
{{- end }}
{{- if (index . "install_vscode_ext_claude_code" | default false) }}
ensure_extension "anthropic.claude-code"
{{- end }}

if [[ "$selected_extension_count" -eq 0 ]]; then
  log "no VSCode extensions selected"
fi
{{ end -}}
