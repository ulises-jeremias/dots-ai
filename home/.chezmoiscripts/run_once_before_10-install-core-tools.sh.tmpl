#!/usr/bin/env bash
set -euo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
fi

log() { printf '%b[core-tools]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[core-tools]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
ok() { printf '%b[core-tools]%b %s\n' "$c_green" "$c_reset" "$*"; }

has_cmd() { command -v "$1" >/dev/null 2>&1; }
can_sudo() { sudo -n true >/dev/null 2>&1; }

install_pkg() {
  pkg="$1"
  if has_cmd "$pkg"; then
    ok "already installed: $pkg"
    return 0
  fi

  if has_cmd pacman; then
    if can_sudo; then sudo pacman -S --noconfirm --needed "$pkg"; else warn "skip $pkg (sudo unavailable)"; fi
  elif has_cmd apt-get; then
    if can_sudo; then sudo apt-get update -y && sudo apt-get install -y "$pkg"; else warn "skip $pkg (sudo unavailable)"; fi
  elif has_cmd dnf; then
    if can_sudo; then sudo dnf install -y "$pkg"; else warn "skip $pkg (sudo unavailable)"; fi
  elif has_cmd brew; then
    brew install "$pkg"
  else
    warn "unsupported OS package manager for $pkg"
  fi
}

{{- $root := . }}
should_install_pkg() {
  pkg="$1"
  case "$pkg" in
    git) [[ "{{ (index $root "install_core_git" | default false) }}" == "true" ]] ;;
    curl) [[ "{{ (index $root "install_core_curl" | default false) }}" == "true" ]] ;;
    wget) [[ "{{ (index $root "install_core_wget" | default false) }}" == "true" ]] ;;
    jq) [[ "{{ (index $root "install_core_jq" | default false) }}" == "true" ]] ;;
    ripgrep) [[ "{{ (index $root "install_core_ripgrep" | default false) }}" == "true" ]] ;;
    fd) [[ "{{ (index $root "install_core_fd" | default false) }}" == "true" ]] ;;
    zsh) [[ "{{ (index $root "install_core_zsh" | default false) }}" == "true" ]] ;;
    neovim) [[ "{{ (index $root "install_core_neovim" | default false) }}" == "true" ]] ;;
    *) return 1 ;;
  esac
}

{{- range .groups.core }}
if should_install_pkg "{{ . }}"; then
  install_pkg "{{ . }}"
else
  log "skipping {{ . }} (user preference)"
fi
{{- end }}
