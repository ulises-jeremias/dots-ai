#!/usr/bin/env bash
set -euo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
fi

log() { printf '%b[core-tools]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[core-tools]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
ok() { printf '%b[core-tools]%b %s\n' "$c_green" "$c_reset" "$*"; }

has_cmd() { command -v "$1" >/dev/null 2>&1; }
can_sudo() { sudo -n true >/dev/null 2>&1; }

# Some packages have a different binary name than their apt package name.
# Returns the apt package name to use for a given canonical package name.
debian_pkg_name() {
  case "$1" in
    fd) echo "fd-find" ;;
    *) echo "$1" ;;
  esac
}

# Checks whether a package is effectively installed, accounting for
# packages whose binary name differs from the package name.
has_pkg() {
  case "$1" in
    fd) has_cmd fd || has_cmd fdfind ;;
    *) has_cmd "$1" ;;
  esac
}

install_github_cli_apt() {
  if ! can_sudo; then
    warn "skip gh (sudo unavailable)"
    return 0
  fi

  sudo apt-get update -y
  sudo apt-get install -y ca-certificates curl
  sudo mkdir -p -m 755 /etc/apt/keyrings
  curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg |
    sudo tee /etc/apt/keyrings/githubcli-archive-keyring.gpg >/dev/null
  sudo chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg

  arch="$(dpkg --print-architecture)"

  sudo mkdir -p /etc/apt/sources.list.d
  printf 'deb [arch=%s signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main\n' "$arch" |
    sudo tee /etc/apt/sources.list.d/github-cli.list >/dev/null
  sudo apt-get update -y
  sudo apt-get install -y gh
}

install_pkg() {
  pkg="$1"
  if has_pkg "$pkg"; then
    ok "already installed: $pkg"
    return 0
  fi

  if has_cmd pacman; then
    if [[ $pkg == gh ]]; then
      if can_sudo; then sudo pacman -S --noconfirm --needed github-cli; else warn "skip $pkg (sudo unavailable)"; fi
      return 0
    fi
    if can_sudo; then sudo pacman -S --noconfirm --needed "$pkg"; else warn "skip $pkg (sudo unavailable)"; fi
  elif has_cmd apt-get; then
    if [[ $pkg == gh ]]; then
      install_github_cli_apt
      return 0
    fi
    apt_pkg="$(debian_pkg_name "$pkg")"
    if can_sudo; then
      sudo apt-get update -y && sudo apt-get install -y "$apt_pkg"
      # Create ~/.local/bin symlink for packages whose binary name differs from the package name.
      case "$pkg" in
        fd)
          if ! has_cmd fd && has_cmd fdfind; then
            mkdir -p "$HOME/.local/bin"
            ln -sf "$(command -v fdfind)" "$HOME/.local/bin/fd"
          fi
          ;;
      esac
    else
      warn "skip $pkg (sudo unavailable)"
    fi
  elif has_cmd dnf; then
    if can_sudo; then sudo dnf install -y "$pkg"; else warn "skip $pkg (sudo unavailable)"; fi
  elif has_cmd brew; then
    brew install "$pkg"
  else
    warn "unsupported OS package manager for $pkg"
  fi
}

{{- range .package_groups.core }}
install_pkg "{{ . }}"
{{- end }}
