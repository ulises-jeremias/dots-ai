#!/usr/bin/env bash
set -euo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
fi

log() { printf '%b[bootstrap-configs]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[bootstrap-configs]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
ok() { printf '%b[bootstrap-configs]%b %s\n' "$c_green" "$c_reset" "$*"; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }

mkdir -p "$HOME/.local/bin"
mkdir -p "$HOME/.local/share/dots-ai/prompts"
mkdir -p "$HOME/.local/share/dots-ai/skills"
mkdir -p "$HOME/.local/share/dots-ai/templates"
mkdir -p "$HOME/.local/share/dots-ai/mcp"

if has_cmd docker; then
  ok "docker detected"
else
  warn "docker not detected; install via profile or platform package manager"
fi

# Activate rtk global hook (compresses CLI outputs before they reach LLM context)
# Redirect stdin from /dev/null to prevent rtk from blocking on interactive prompts
if has_cmd rtk; then
  log "activating rtk global hook..."
  rtk init --global </dev/null 2>/dev/null && ok "rtk global hook active" || warn "rtk init skipped (already active or non-interactive)"
else
  warn "rtk not installed; skipping hook activation"
fi

ok "bootstrap completed"
