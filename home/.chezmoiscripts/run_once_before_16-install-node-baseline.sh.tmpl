#!/usr/bin/env bash
# chezmoi:template:left-delimiter="{{" right-delimiter="}}"
#
# Node baseline — always installed (not profile-gated).
# Required by: uipro, claude-code, opencode (npm path), pi, and many AI tool CLIs.
set -eo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
fi

log() { printf '%b[node-baseline]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[node-baseline]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
ok() { printf '%b[node-baseline]%b %s\n' "$c_green" "$c_reset" "$*"; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }
can_sudo() { sudo -n true >/dev/null 2>&1; }
is_arch() { has_cmd pacman; }
has_brew() { has_cmd brew; }

# ---------------------------------------------------------------------------
# Install fnm if missing
# ---------------------------------------------------------------------------
if ! has_cmd fnm; then
  log "installing fnm..."
  if is_arch; then
    if can_sudo; then sudo pacman -S --noconfirm --needed fnm; else warn "skip fnm (sudo unavailable)"; fi
  elif has_brew; then
    brew install fnm
  else
    curl -fsSL https://fnm.vercel.app/install | bash
    # Add fnm binary to PATH within this script session so subsequent commands find it
    for fnm_candidate in \
      "$HOME/.local/share/fnm" \
      "$HOME/.fnm"; do
      if [[ -f "${fnm_candidate}/fnm" ]]; then
        export PATH="${fnm_candidate}:$PATH"
        eval "$("${fnm_candidate}/fnm" env --use-on-cd 2>/dev/null)" || true
        break
      fi
    done
  fi
else
  ok "fnm already installed: $(fnm --version 2>&1)"
fi

# ---------------------------------------------------------------------------
# Install Node.js LTS via fnm if missing
# ---------------------------------------------------------------------------
if has_cmd fnm && ! has_cmd node; then
  log "installing Node.js LTS via fnm..."
  fnm install --lts
  fnm default lts-latest
  eval "$(fnm env --use-on-cd 2>/dev/null)" || true
  # Also export node path so subsequent steps in this shell session find it
  FNM_MULTISHELL_PATH=$(fnm env 2>/dev/null | grep "FNM_MULTISHELL_PATH" | cut -d= -f2 | tr -d '"' || true)
  if [[ -n "$FNM_MULTISHELL_PATH" ]]; then
    export PATH="${FNM_MULTISHELL_PATH}:$PATH"
  fi
fi

if has_cmd node; then
  ok "node already installed: $(node --version 2>&1)"
else
  warn "node not available after fnm setup — restart your shell"
fi

# ---------------------------------------------------------------------------
# Ensure pnpm is available
# ---------------------------------------------------------------------------
if has_cmd node && ! has_cmd pnpm; then
  log "installing pnpm..."
  if has_cmd corepack; then
    corepack enable pnpm
    corepack prepare pnpm@latest --activate
  elif has_cmd npm; then
    npm install -g pnpm
  elif has_cmd fnm; then
    eval "$(fnm env --use-on-cd 2>/dev/null)" || true
    if has_cmd npm; then
      npm install -g pnpm
    else
      warn "npm not available via fnm node — skipping pnpm"
    fi
  else
    warn "no package manager available for pnpm"
  fi
fi

if has_cmd pnpm; then
  ok "pnpm already installed: $(pnpm --version 2>&1)"
fi

log "node baseline complete"
