#!/usr/bin/env bash
set -euo pipefail

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_yellow=$'\033[1;33m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_yellow=''
  c_green=''
fi

log() { printf '%b[editors]%b %s\n' "$c_blue" "$c_reset" "$*"; }
warn() { printf '%b[editors]%b %s\n' "$c_yellow" "$c_reset" "$*"; }
ok() { printf '%b[editors]%b %s\n' "$c_green" "$c_reset" "$*"; }
has_cmd() { command -v "$1" >/dev/null 2>&1; }
can_sudo() { sudo -n true >/dev/null 2>&1; }

aur_install() {
  local pkg="$1"
  if has_cmd paru; then
    paru -S --noconfirm --needed "$pkg"
  elif has_cmd yay; then
    yay -S --noconfirm --needed "$pkg"
  else
    warn "AUR helper (paru/yay) not found; cannot install $pkg via AUR"
    return 1
  fi
}

install_vscode() {
  if has_cmd code; then
    ok "VSCode already installed"
    return 0
  fi

  if has_cmd pacman; then
    if can_sudo; then
      sudo pacman -S --noconfirm --needed code || warn "failed to install VSCode with pacman"
    else
      warn "skip VSCode install (sudo unavailable)"
    fi
  elif has_cmd apt-get; then
    if can_sudo; then
      sudo apt-get update -y && sudo apt-get install -y code || warn "VSCode apt package unavailable; configure Microsoft repo or install manually"
    else
      warn "skip VSCode install (sudo unavailable)"
    fi
  elif has_cmd dnf; then
    if can_sudo; then
      sudo dnf install -y code || warn "VSCode dnf package unavailable; configure Microsoft repo or install manually"
    else
      warn "skip VSCode install (sudo unavailable)"
    fi
  elif has_cmd brew; then
    brew install --cask visual-studio-code || warn "failed to install VSCode with brew"
  else
    warn "unsupported package manager for VSCode installation"
  fi
}

install_cursor() {
  if has_cmd cursor; then
    ok "Cursor already installed"
    return 0
  fi

  if has_cmd pacman; then
    aur_install cursor-bin || warn "failed to install Cursor from AUR"
  elif has_cmd brew; then
    brew install --cask cursor || warn "failed to install Cursor with brew"
  else
    warn "automatic Cursor installation is not configured for this OS; install manually"
  fi
}

install_vscode_flag="{{ (index . "install_editor_vscode" | default false) }}"
install_cursor_flag="{{ (index . "install_editor_cursor" | default false) }}"

if [[ "$install_vscode_flag" != "true" && "$install_cursor_flag" != "true" ]]; then
  log "no editor installations selected"
  exit 0
fi

if [[ "$install_vscode_flag" == "true" ]]; then
  log "checking VSCode..."
  install_vscode
fi

if [[ "$install_cursor_flag" == "true" ]]; then
  log "checking Cursor..."
  install_cursor
fi
