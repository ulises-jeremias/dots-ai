# Confluence Assistant Skills — copy to `confluence.env` and fill values.
#
# Enable:
#   cp ~/.config/dots-ai/env.d/confluence.env.example ~/.config/dots-ai/env.d/confluence.env
# Disable:
#   mv ~/.config/dots-ai/env.d/confluence.env ~/.config/dots-ai/env.d/confluence.env.disabled

export CONFLUENCE_SITE_URL="https://your-company.atlassian.net"
export CONFLUENCE_EMAIL="you@company.com"
export CONFLUENCE_API_TOKEN="your-api-token-here"
