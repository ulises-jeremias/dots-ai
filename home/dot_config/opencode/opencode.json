{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "colibri": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Colibri Local LLM",
      "options": {
        "baseURL": "http://colibri.skypiea.local:8000/v1"
      },
      "models": {
        "qwen3-coder-next": {
          "name": "Qwen3 Coder Next (Code)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        },
        "qwen3-next-80b": {
          "name": "Qwen3 Next 80B (Chat)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  }
}