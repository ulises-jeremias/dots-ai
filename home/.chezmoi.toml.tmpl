{{- $interactive := stdinIsATTY -}}
{{- $initQuestionnaireCompleted := (index . "init_questionnaire_completed" | default false) -}}
{{- $shouldAskInitQuestions := and $interactive (not $initQuestionnaireCompleted) -}}

{{- /* Docker — opt-in */ -}}
{{- $installDockerDocker := (index . "install_docker_docker" | default false) -}}

{{- /* AI coding agents — opt-in per tool */ -}}
{{- $installAgentClaudeCode := (index . "install_agent_claude_code" | default false) -}}
{{- $installAgentOpencode := (index . "install_agent_opencode" | default false) -}}
{{- $installAgentPi := (index . "install_agent_pi" | default false) -}}
{{- $installAgentCopilotCli := (index . "install_agent_copilot_cli" | default false) -}}

{{- /* Editors — opt-in */ -}}
{{- $installEditorVscode := (index . "install_editor_vscode" | default false) -}}
{{- $installEditorCursor := (index . "install_editor_cursor" | default false) -}}
{{- $installVscodeExtGitlens := (index . "install_vscode_ext_gitlens" | default false) -}}
{{- $installVscodeExtEditorconfig := (index . "install_vscode_ext_editorconfig" | default false) -}}
{{- $installVscodeExtCopilot := (index . "install_vscode_ext_copilot" | default false) -}}
{{- $installVscodeExtCopilotChat := (index . "install_vscode_ext_copilot_chat" | default false) -}}
{{- $installVscodeExtPython := (index . "install_vscode_ext_python" | default false) -}}
{{- $installVscodeExtYaml := (index . "install_vscode_ext_yaml" | default false) -}}
{{- $installVscodeExtSpellcheck := (index . "install_vscode_ext_spellcheck" | default false) -}}
{{- $installVscodeExtMarkdown := (index . "install_vscode_ext_markdown" | default false) -}}
{{- $installVscodeExtClaudeCode := (index . "install_vscode_ext_claude_code" | default false) -}}

{{- /* Config overlays — opt-in */ -}}
{{- $applyGitconfig := (index . "apply_gitconfig" | default false) -}}
{{- $applyZshrc := (index . "apply_zshrc" | default false) -}}

{{- if $shouldAskInitQuestions -}}
{{-   $dockerSection := "\n  ═══════════════════════════════════════════════════════════\n  ║  DOCKER\n  ╚══════════════════════════════════════════════════════════" -}}
{{-   $installDockerDocker = promptBoolOnce . "install_docker_docker" (printf "%s\n  Install Docker CLI?" $dockerSection) false -}}

{{-   $aiSection := "\n  ═══════════════════════════════════════════════════════════\n  ║  AI CODING AGENTS\n  ╚══════════════════════════════════════════════════════════" -}}
{{-   $installAgentClaudeCode = promptBoolOnce . "install_agent_claude_code" (printf "%s\n  Install Claude Code CLI?" $aiSection) false -}}
{{-   $installAgentOpencode = promptBoolOnce . "install_agent_opencode" "  Install OpenCode? (Recommended - free built-in model)" false -}}
{{-   $installAgentPi = promptBoolOnce . "install_agent_pi" "  Install pi coding agent?" false -}}
{{-   $installAgentCopilotCli = promptBoolOnce . "install_agent_copilot_cli" "  Install GitHub Copilot CLI?" false -}}

{{-   $editorSection := "\n  ═══════════════════════════════════════════════════════════\n  ║  EDITORS\n  ╚══════════════════════════════════════════════════════════" -}}
{{-   $installEditorVscode = promptBoolOnce . "install_editor_vscode" (printf "%s\n  Install VSCode?" $editorSection) false -}}
{{-   $installEditorCursor = promptBoolOnce . "install_editor_cursor" "  Install Cursor (AI editor)?" false -}}

{{-   if $installEditorVscode -}}
{{-     $extSection := "\n  ═══════════════════════════════════════════════════════════\n  ║  VSCODE EXTENSIONS\n  ╚══════════════════════════════════════════════════════════" -}}
{{-     $installVscodeExtGitlens = promptBoolOnce . "install_vscode_ext_gitlens" (printf "%s\n  GitLens?" $extSection) false -}}
{{-     $installVscodeExtEditorconfig = promptBoolOnce . "install_vscode_ext_editorconfig" "  EditorConfig?" false -}}
{{-     $installVscodeExtCopilot = promptBoolOnce . "install_vscode_ext_copilot" "  GitHub Copilot?" false -}}
{{-     $installVscodeExtCopilotChat = promptBoolOnce . "install_vscode_ext_copilot_chat" "  GitHub Copilot Chat?" false -}}
{{-     $installVscodeExtPython = promptBoolOnce . "install_vscode_ext_python" "  Python (Microsoft)?" false -}}
{{-     $installVscodeExtYaml = promptBoolOnce . "install_vscode_ext_yaml" "  YAML?" false -}}
{{-     $installVscodeExtSpellcheck = promptBoolOnce . "install_vscode_ext_spellcheck" "  Code Spell Checker?" false -}}
{{-     $installVscodeExtMarkdown = promptBoolOnce . "install_vscode_ext_markdown" "  Markdown All in One?" false -}}
{{-     $installVscodeExtClaudeCode = promptBoolOnce . "install_vscode_ext_claude_code" "  Claude Code?" false -}}
{{-   end -}}

{{-   $configSection := "\n  ═══════════════════════════════════════════════════════════\n  ║  CONFIG OVERLAYS\n  ╚══════════════════════════════════════════════════════════" -}}
{{-   $applyGitconfig = promptBoolOnce . "apply_gitconfig" (printf "%s\n  Apply dots-ai gitconfig?" $configSection) false -}}
{{-   $applyZshrc = promptBoolOnce . "apply_zshrc" "  Apply dots-ai zshrc?" false -}}

{{-   $initQuestionnaireCompleted = true -}}
{{- end -}}

[data]
  init_questionnaire_completed = {{ $initQuestionnaireCompleted }}
  enable_node = true
  enable_python = true
  enable_docker = {{ $installDockerDocker }}
  enable_ai = true
  install_node_fnm = true
  install_node_nodejs = true
  install_node_pnpm = true
  install_python_python = true
  install_python_uv = true
  install_python_pipx = true
  install_docker_docker = {{ $installDockerDocker }}
  install_agent_clickup_cli = true
  install_agent_slack_cli = true
  install_agent_rtk = true
  install_agent_uipro_cli = true
  install_agent_claude_code = {{ $installAgentClaudeCode }}
  install_agent_opencode = {{ $installAgentOpencode }}
  install_agent_pi = {{ $installAgentPi }}
  install_agent_copilot_cli = {{ $installAgentCopilotCli }}
  install_skill_jira_assistant = true
  install_skill_confluence_assistant = true
  install_editor_vscode = {{ $installEditorVscode }}
  install_editor_cursor = {{ $installEditorCursor }}
  install_vscode_ext_gitlens = {{ $installVscodeExtGitlens }}
  install_vscode_ext_editorconfig = {{ $installVscodeExtEditorconfig }}
  install_vscode_ext_copilot = {{ $installVscodeExtCopilot }}
  install_vscode_ext_copilot_chat = {{ $installVscodeExtCopilotChat }}
  install_vscode_ext_python = {{ $installVscodeExtPython }}
  install_vscode_ext_yaml = {{ $installVscodeExtYaml }}
  install_vscode_ext_spellcheck = {{ $installVscodeExtSpellcheck }}
  install_vscode_ext_markdown = {{ $installVscodeExtMarkdown }}
  install_vscode_ext_claude_code = {{ $installVscodeExtClaudeCode }}
  apply_gitconfig = {{ $applyGitconfig }}
  apply_zshrc = {{ $applyZshrc }}
