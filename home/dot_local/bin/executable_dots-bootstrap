#!/usr/bin/env bash
set -eo pipefail

## dots-bootstrap
##
## Bootstrap helper for the dots-ai workstation baseline.
##
## Usage:
##     @script.name [option]
##
## Options:
##     -h, --help              Show this help message.
##         --apply              Apply changes with chezmoi.
##
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_DOTS_AI_LIB_DIR="$(cd -- "${SCRIPT_DIR}/../lib/dots-ai" 2>/dev/null && pwd || true)"
DOTS_AI_LIB_DIR="${DOTS_AI_LIB_DIR:-${DEFAULT_DOTS_AI_LIB_DIR:-$HOME/.local/lib/dots-ai}}"
EASY_OPTIONS_LIB="${DOTS_AI_LIB_DIR}/easy-options/easyoptions.sh"

if [[ ! -f "${EASY_OPTIONS_LIB}" ]]; then
  echo "[dots-bootstrap] Missing dependency: ${EASY_OPTIONS_LIB}" >&2
  exit 1
fi
source "${EASY_OPTIONS_LIB}"

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_green=$'\033[1;32m'
else
  c_reset=''
  c_blue=''
  c_green=''
fi

info() { printf '%b[dots-bootstrap]%b %s\n' "$c_blue" "$c_reset" "$*"; }
ok() { printf '%b[dots-bootstrap]%b %s\n' "$c_green" "$c_reset" "$*"; }

info "dots-ai workstation bootstrap"
info "1) chezmoi apply --dry-run"
info "2) chezmoi apply"
info "3) dots-doctor"

if [[ -n "${apply:-}" ]]; then
  ok "running: chezmoi apply"
  exec chezmoi apply
fi

ok "dry-run plan displayed (pass --apply to execute)"
