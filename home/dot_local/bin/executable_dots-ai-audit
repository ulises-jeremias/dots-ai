#!/usr/bin/env bash
set -euo pipefail

## dots-ai-audit
##
## Audits local AI tool installation, authentication hints, and safe configuration metadata.
## It never prints token values, raw auth files, prompt history, or chat contents.
##
## Usage:
##     @script.name [options]
##
## Options:
##     -h, --help              Show this help message.
##     --json                  Emit a single JSON report.
##     --issue, --paste        Emit a Markdown-friendly report.
##     --no-network            Do not run commands that may contact vendor services.

MODE="human"
NO_NETWORK=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h | --help)
      sed -n '3,18p' "$0" | sed 's/^## \{0,1\}//'
      exit 0
      ;;
    --json)
      MODE="json"
      shift
      ;;
    --issue | --paste)
      MODE="issue"
      shift
      ;;
    --no-network)
      NO_NETWORK=1
      shift
      ;;
    *)
      echo "[dots-ai-audit] unknown option: $1 (try --help)" >&2
      exit 2
      ;;
  esac
done

tools_json="[]"

if [[ -t 1 && -z ${NO_COLOR:-} && ${MODE} == "human" ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_green=$'\033[1;32m'
  c_yellow=$'\033[1;33m'
else
  c_reset=''
  c_blue=''
  c_green=''
  c_yellow=''
fi

info() { [[ ${MODE} == "human" ]] && printf '%b[dots-ai-audit]%b %s\n' "$c_blue" "$c_reset" "$*"; }
ok() { [[ ${MODE} == "human" ]] && printf '  %b[OK]%b %s\n' "$c_green" "$c_reset" "$*"; }
warn() { [[ ${MODE} == "human" ]] && printf '  %b[WARN]%b %s\n' "$c_yellow" "$c_reset" "$*"; }

sanitize() {
  printf '%s' "${1:-}" |
    sed -E \
      -e 's/(sk-[A-Za-z0-9_-]{8,})/[REDACTED_TOKEN]/g' \
      -e 's/(gh[pousr]_[A-Za-z0-9_]{8,})/[REDACTED_TOKEN]/g' \
      -e 's/([A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Za-z]{2,})/[REDACTED_EMAIL]/g' |
    tr '`' "'" |
    tr '\n\r' '  ' |
    head -c 300
}

bool_path() {
  [[ -e $1 ]] && printf 'true' || printf 'false'
}

version_for() {
  local cmd="$1"
  command -v "$cmd" >/dev/null 2>&1 || return
  "$cmd" --version 2>/dev/null | head -n 1 || true
}

append_tool() {
  local json="$1"
  tools_json=$(TOOLS_JSON="$tools_json" TOOL_JSON="$json" python3 - <<'PY'
import json, os
items = json.loads(os.environ["TOOLS_JSON"])
items.append(json.loads(os.environ["TOOL_JSON"]))
print(json.dumps(items))
PY
)
}

json_tool() {
  local tool="$1" installed="$2" version="$3" auth_state="$4" identity="$5" subscription_state="$6" subscription_evidence="$7" warnings="$8" configs="$9" privacy="${10}"
  TOOL="$tool" INSTALLED="$installed" VERSION="$version" AUTH_STATE="$auth_state" IDENTITY="$identity" SUB_STATE="$subscription_state" SUB_EVIDENCE="$subscription_evidence" WARNINGS="$warnings" CONFIGS="$configs" PRIVACY="$privacy" python3 - <<'PY'
import json, os
def split(v):
    return [x for x in v.split('|') if x]
print(json.dumps({
    "tool": os.environ["TOOL"],
    "installed": os.environ["INSTALLED"] == "true",
    "version": os.environ["VERSION"] or None,
    "auth": {
        "state": os.environ["AUTH_STATE"] or "unknown",
        "identity": os.environ["IDENTITY"] or None,
        "identity_confidence": "medium" if os.environ["IDENTITY"] else "low",
    },
    "subscription": {
        "state": os.environ["SUB_STATE"] or "unknown",
        "evidence": os.environ["SUB_EVIDENCE"] or None,
        "confidence": "low",
    },
    "config_files": split(os.environ["CONFIGS"]),
    "privacy": split(os.environ["PRIVACY"]),
    "warnings": split(os.environ["WARNINGS"]),
}))
PY
}

gh_identity() {
  [[ ${NO_NETWORK} -eq 1 ]] && return
  command -v gh >/dev/null 2>&1 || return
  gh auth status 2>&1 | sed -n 's/.*Logged in to github\.com account \([^[:space:]]*\).*/\1/p' | head -n 1
}

codex_auth_state() {
  [[ ${NO_NETWORK} -eq 1 ]] && return
  command -v codex >/dev/null 2>&1 || return
  codex login status 2>/dev/null | head -n 1 || true
}

opencode_auth_state() {
  [[ ${NO_NETWORK} -eq 1 ]] && return
  command -v opencode >/dev/null 2>&1 || return
  { opencode providers list 2>/dev/null | grep -E '^[[:space:]]*[A-Za-z0-9._ -]+[[:space:]]+' || true; } | wc -l | tr -d ' '
}

collect_claude() {
  local installed=false version="" configs="" privacy="" warnings="" auth="unknown"
  if command -v claude >/dev/null 2>&1; then installed=true; version="$(sanitize "$(version_for claude)")"; fi
  for p in "$HOME/.claude/settings.json" "$HOME/.claude.json" "/etc/claude-code/managed-settings.json"; do
    [[ -e $p ]] && configs="${configs}|${p}"
  done
  [[ -f $HOME/.claude/settings.json ]] && privacy="${privacy}|settings.json present"
  [[ -f $HOME/.claude.json ]] && warnings="${warnings}|~/.claude.json may include OAuth/session metadata; not inspected"
  [[ ${installed} == true ]] && auth="installed; account not available non-interactively"
  append_tool "$(json_tool claude "$installed" "$version" "$auth" "" unknown "Claude subscription is server-side" "$warnings" "$configs" "$privacy")"
}

collect_cursor() {
  local installed=false version="" configs="" privacy="" warnings=""
  if command -v cursor >/dev/null 2>&1; then installed=true; version="$(sanitize "$(version_for cursor)")"; fi
  for p in "$HOME/.cursor" "$HOME/.cursor/mcp.json" "$HOME/.config/Cursor/User/settings.json" "$HOME/.config/Cursor/User/globalStorage/state.vscdb"; do
    [[ -e $p ]] && configs="${configs}|${p}"
  done
  [[ -f $HOME/.config/Cursor/User/settings.json ]] && privacy="${privacy}|Cursor user settings present"
  [[ -f $HOME/.config/Cursor/User/globalStorage/state.vscdb ]] && warnings="${warnings}|Cursor globalStorage SQLite present; not inspected"
  append_tool "$(json_tool cursor "$installed" "$version" unknown "" unknown "Cursor account/subscription is app-managed" "$warnings" "$configs" "$privacy")"
}

collect_copilot() {
  local installed=false version="" configs="" privacy="" warnings="" auth="unknown" identity=""
  if command -v gh >/dev/null 2>&1; then
    version="$(sanitize "$(version_for gh)")"
    if [[ ${NO_NETWORK} -eq 0 ]]; then
      auth="$(sanitize "$(gh auth status 2>&1 | head -n 1 || true)")"
      identity="$(sanitize "$(gh_identity)")"
    else
      [[ -f $HOME/.config/gh/hosts.yml ]] && auth="GitHub CLI auth config present; not checked due to --no-network"
    fi
  fi
  if command -v code >/dev/null 2>&1 && code --list-extensions 2>/dev/null | grep -qi '^GitHub\.copilot'; then installed=true; fi
  [[ -f $HOME/.config/Code/User/settings.json ]] && configs="${configs}|$HOME/.config/Code/User/settings.json"
  [[ -f $HOME/.config/gh/hosts.yml ]] && configs="${configs}|$HOME/.config/gh/hosts.yml"
  [[ -f $HOME/.github/copilot-instructions.md ]] && configs="${configs}|$HOME/.github/copilot-instructions.md"
  [[ -f $HOME/.config/Code/User/settings.json ]] && privacy="${privacy}|VS Code Copilot settings may be present"
  warnings="${warnings}|Copilot entitlement cannot be proven from local files alone"
  append_tool "$(json_tool copilot "$installed" "$version" "$auth" "$identity" unknown "Use GitHub org/user admin APIs for entitlement" "$warnings" "$configs" "$privacy")"
}

collect_opencode() {
  local installed=false version="" configs="" privacy="" warnings="" auth="unknown" count=""
  if command -v opencode >/dev/null 2>&1; then installed=true; version="$(sanitize "$(version_for opencode)")"; count="$(opencode_auth_state)"; [[ -n $count ]] && auth="configured providers: $count"; fi
  for p in "$HOME/.config/opencode/opencode.json" "$HOME/.config/opencode/tui.json" "$HOME/.local/share/opencode/auth.json"; do
    [[ -e $p ]] && configs="${configs}|${p}"
  done
  [[ -f $HOME/.config/opencode/opencode.json ]] && privacy="${privacy}|Inspect share, permission, enabled_providers, disabled_providers"
  [[ -f $HOME/.local/share/opencode/auth.json ]] && warnings="${warnings}|OpenCode auth.json present; not inspected"
  append_tool "$(json_tool opencode "$installed" "$version" "$auth" "" unknown "Provider-specific subscription" "$warnings" "$configs" "$privacy")"
}

collect_codex() {
  local installed=false version="" configs="" privacy="" warnings="" auth="unknown" evidence=""
  if command -v codex >/dev/null 2>&1; then installed=true; version="$(sanitize "$(version_for codex)")"; auth="$(sanitize "$(codex_auth_state)")"; evidence="$auth"; fi
  for p in "$HOME/.codex/config.toml" "$HOME/.codex/auth.json"; do
    [[ -e $p ]] && configs="${configs}|${p}"
  done
  [[ -f $HOME/.codex/config.toml ]] && privacy="${privacy}|Inspect analytics.enabled, feedback.enabled, history.persistence, approval_policy, sandbox_mode"
  [[ -f $HOME/.codex/auth.json ]] && warnings="${warnings}|Codex auth.json may contain access tokens; not inspected"
  append_tool "$(json_tool codex "$installed" "$version" "$auth" "" unknown "$evidence" "$warnings" "$configs" "$privacy")"
}

collect_windsurf() {
  local installed=false version="" configs="" privacy="" warnings=""
  if command -v windsurf >/dev/null 2>&1; then installed=true; version="$(sanitize "$(version_for windsurf)")"; fi
  for p in "$HOME/.codeium/windsurf" "$HOME/.codeium/windsurf/memories" "$HOME/.windsurf/rules"; do
    [[ -e $p ]] && configs="${configs}|${p}"
  done
  [[ -d $HOME/.codeium/windsurf/memories ]] && warnings="${warnings}|Windsurf memories present; content not inspected"
  append_tool "$(json_tool windsurf "$installed" "$version" unknown "" unknown "Windsurf account/subscription is app-managed" "$warnings" "$configs" "$privacy")"
}

collect_gemini() {
  local installed=false version="" configs="" privacy="" warnings=""
  if command -v gemini >/dev/null 2>&1; then installed=true; version="$(sanitize "$(version_for gemini)")"; fi
  [[ -f $HOME/.gemini/settings.json ]] && configs="${configs}|$HOME/.gemini/settings.json" && privacy="${privacy}|Inspect telemetry, sandbox, trusted folders, MCP settings"
  [[ -n ${GEMINI_API_KEY:-} || -n ${GOOGLE_API_KEY:-} ]] && warnings="${warnings}|Gemini/OpenAI-style API key env var present (value hidden)"
  append_tool "$(json_tool gemini "$installed" "$version" unknown "" unknown "Google account/project state is server-side" "$warnings" "$configs" "$privacy")"
}

collect_claude
collect_cursor
collect_copilot
collect_opencode
collect_codex
collect_windsurf
collect_gemini

if [[ ${MODE} == "json" ]]; then
  TOOLS_JSON="$tools_json" python3 - <<'PY'
import json, os
tools = json.loads(os.environ["TOOLS_JSON"])
print(json.dumps({
  "schema_version": 1,
  "scope": "dots-ai",
  "tools_detected": sum(1 for t in tools if t["installed"] or t["config_files"]),
  "tools": tools,
}, sort_keys=True))
PY
elif [[ ${MODE} == "issue" ]]; then
  TOOLS_JSON="$tools_json" python3 - <<'PY'
import json, os
tools = json.loads(os.environ["TOOLS_JSON"])
print("## dots-ai audit\n")
print("_No token values, auth file contents, prompt history, or chat contents are included._\n")
for t in tools:
    marker = "[x]" if t["installed"] or t["config_files"] else "[ ]"
    print(f"- {marker} **{t['tool']}** — auth: `{t['auth']['state']}`; configs: {len(t['config_files'])}; warnings: {len(t['warnings'])}")
PY
else
  info "AI tool audit (safe metadata only)"
  TOOLS_JSON="$tools_json" python3 - <<'PY'
import json, os
for t in json.loads(os.environ["TOOLS_JSON"]):
    label = "detected" if t["installed"] or t["config_files"] else "not detected"
    print(f"  [{label}] {t['tool']}: auth={t['auth']['state']} configs={len(t['config_files'])} warnings={len(t['warnings'])}")
PY
fi
