#!/usr/bin/env bash
set -eo pipefail

## dots-sync-ai
##
## Validates that AI asset directories exist locally.
##
## Usage:
##     @script.name [option]
##
## Options:
##     -h, --help              Show this help message.
##
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_DOTS_AI_LIB_DIR="$(cd -- "${SCRIPT_DIR}/../lib/dots-ai" 2>/dev/null && pwd || true)"
DOTS_AI_LIB_DIR="${DOTS_AI_LIB_DIR:-${DEFAULT_DOTS_AI_LIB_DIR:-$HOME/.local/lib/dots-ai}}"
EASY_OPTIONS_LIB="${DOTS_AI_LIB_DIR}/easy-options/easyoptions.sh"

if [[ ! -f "${EASY_OPTIONS_LIB}" ]]; then
	echo "[dots-sync-ai] Missing dependency: ${EASY_OPTIONS_LIB}" >&2
	exit 1
fi
source "${EASY_OPTIONS_LIB}"

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
	c_reset=$'\033[0m'
	c_blue=$'\033[1;34m'
	c_red=$'\033[1;31m'
	c_green=$'\033[1;32m'
else
	c_reset=''
	c_blue=''
	c_red=''
	c_green=''
fi

info() { printf '%b[dots-sync-ai]%b %s\n' "$c_blue" "$c_reset" "$*"; }
fail() { printf '%b[dots-sync-ai]%b %s\n' "$c_red" "$c_reset" "$*"; }
ok() { printf '%b[dots-sync-ai]%b %s\n' "$c_green" "$c_reset" "$*"; }

base="${HOME}/.local/share/dots-ai"
info "validating AI assets at ${base}"
for dir in prompts skills templates; do
	if [[ ! -d "${base}/${dir}" ]]; then
		fail "Missing AI directory: ${base}/${dir}" >&2
		exit 1
	fi
	ok "found: ${base}/${dir}"
done

ok "AI assets are present under ${base}"
