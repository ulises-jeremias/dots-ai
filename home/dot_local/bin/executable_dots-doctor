#!/usr/bin/env bash
set -eo pipefail

## dots-doctor
##
## Runs baseline health checks for dots-ai workstation tooling.
##
## Usage:
##     @script.name [option]
##
## Options:
##     -h, --help              Show this help message.
##
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_DOTS_AI_LIB_DIR="$(cd -- "${SCRIPT_DIR}/../lib/dots-ai" 2>/dev/null && pwd || true)"
DOTS_AI_LIB_DIR="${DOTS_AI_LIB_DIR:-${DEFAULT_DOTS_AI_LIB_DIR:-$HOME/.local/lib/dots-ai}}"
EASY_OPTIONS_LIB="${DOTS_AI_LIB_DIR}/easy-options/easyoptions.sh"

if [[ ! -f "${EASY_OPTIONS_LIB}" ]]; then
  echo "[dots-doctor] Missing dependency: ${EASY_OPTIONS_LIB}" >&2
  exit 1
fi
source "${EASY_OPTIONS_LIB}"

errors=0
checks=0
passed=0

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_green=$'\033[1;32m'
  c_red=$'\033[1;31m'
  c_yellow=$'\033[1;33m'
else
  c_reset=''
  c_blue=''
  c_green=''
  c_red=''
  c_yellow=''
fi

info() { printf '%b[dots-doctor]%b %s\n' "$c_blue" "$c_reset" "$*"; }
ok() { printf '  %b[OK]%b %s\n' "$c_green" "$c_reset" "$*"; }
fail() { printf '  %b[FAIL]%b %s\n' "$c_red" "$c_reset" "$*"; }
warn() { printf '%b[dots-doctor]%b %s\n' "$c_yellow" "$c_reset" "$*"; }

check_cmd() {
  checks=$((checks + 1))
  info "checking command: $1"
  if ! command -v "$1" >/dev/null 2>&1; then
    fail "missing command: $1"
    errors=$((errors + 1))
    return
  fi
  local version
  version="$("$1" --version 2>/dev/null | head -n 1 || true)"
  if [[ -n "${version}" ]]; then
    ok "$1 available (${version})"
  else
    ok "$1 available"
  fi
  passed=$((passed + 1))
}

check_dir() {
  checks=$((checks + 1))
  info "checking directory: $1"
  if [[ ! -d "$1" ]]; then
    fail "missing directory: $1"
    errors=$((errors + 1))
    return
  fi
  ok "directory present: $1"
  passed=$((passed + 1))
}

info "starting dots-ai workstation health checks"

for cmd in git curl wget jq rg fd zsh nvim fnm node uv python3 docker; do
  check_cmd "$cmd"
done

check_dir "${HOME}/.local/share/dots-ai/prompts"
check_dir "${HOME}/.local/share/dots-ai/skills"
check_dir "${HOME}/.local/share/dots-ai/templates"
check_dir "${HOME}/.local/share/dots-ai/mcp/github"
check_dir "${HOME}/.local/share/dots-ai/mcp/clickup"
check_dir "${HOME}/.local/share/dots-ai/mcp/notion"
check_dir "${HOME}/.local/share/dots-ai/mcp/slack"

info "checks completed: ${passed}/${checks} passed"

if [[ ${errors} -gt 0 ]]; then
  warn "result: NON-COMPLIANT (${errors} failures)"
  echo "Your workstation environment appears to be out of compliance with the dots-ai baseline. Please run dots-doctor --help for guidance."
  exit 1
fi

info "result: COMPLIANT"
echo "Workstation looks compliant with dots-ai baseline."
