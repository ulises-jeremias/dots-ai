#!/usr/bin/env bash
set -eo pipefail

## dots-skills
##
## Manage dots-ai AI skills across multiple AI tools.
##
## Usage:
##     @script.name <command> [options]
##
## Commands:
##     list                 List installed skills and their status per AI tool.
##     sync                 Regenerate symlinks for all skills (reads skill.json compatibility).
##     install <name>       Install an npm-sourced skill from the registry.
##     check                Validate that required tools and pip packages are installed.
##     add <source>         Add an npm skill to the registry: npm:<pkg>.
##
## Note: github and url skills are managed by chezmoi (.chezmoiexternal).
##       Enable them in chezmoi config and run: chezmoi apply
##
## Options:
##     -h, --help           Show this help message.
##

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_DOTS_AI_LIB_DIR="$(cd -- "${SCRIPT_DIR}/../lib/dots-ai" 2>/dev/null && pwd || true)"
DOTS_AI_LIB_DIR="${DOTS_AI_LIB_DIR:-${DEFAULT_DOTS_AI_LIB_DIR:-$HOME/.local/lib/dots-ai}}"
EASY_OPTIONS_LIB="${DOTS_AI_LIB_DIR}/easy-options/easyoptions.sh"

if [[ ! -f "${EASY_OPTIONS_LIB}" ]]; then
  echo "[dots-skills] Missing dependency: ${EASY_OPTIONS_LIB}" >&2
  exit 1
fi
source "${EASY_OPTIONS_LIB}"

# ── Paths ─────────────────────────────────────────────────────────────────────

DOTS_AI_SHARE="${HOME}/.local/share/dots-ai"
SKILLS_DIR="${DOTS_AI_SHARE}/skills"
SKILLS_EXTERNAL_DIR="${DOTS_AI_SHARE}/skills-external"
REGISTRY_FILE="${DOTS_AI_SHARE}/skills-registry.yaml"

# ── AI Tool → Skills Directory mapping ────────────────────────────────────────
# Keys must match the tool keys used in skill.json compatibility blocks.

declare -A TOOL_DIRS=(
  ["claude-code"]="${HOME}/.claude/skills"
  ["copilot-cli"]="${HOME}/.copilot/skills"
  ["cursor"]="${HOME}/.cursor/skills"
  ["opencode"]="${HOME}/.config/opencode/skills"
  ["pi"]="${HOME}/.pi/agent/skills"
  ["windsurf"]="${HOME}/.windsurf/skills"
)

# ── Colors ────────────────────────────────────────────────────────────────────

if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_green=$'\033[1;32m'
  c_red=$'\033[1;31m'
  c_yellow=$'\033[1;33m'
  c_bold=$'\033[1m'
  c_dim=$'\033[2m'
else
  c_reset='' c_blue='' c_green='' c_red='' c_yellow='' c_bold='' c_dim=''
fi

info()  { printf '%b[dots-skills]%b %s\n' "$c_blue"   "$c_reset" "$*"; }
ok()    { printf '  %b✓%b %s\n'          "$c_green"  "$c_reset" "$*"; }
fail()  { printf '  %b✗%b %s\n'          "$c_red"    "$c_reset" "$*"; }
warn()  { printf '  %b!%b %s\n'          "$c_yellow" "$c_reset" "$*"; }
die()   { printf '%b[dots-skills] error:%b %s\n' "$c_red" "$c_reset" "$*" >&2; exit 1; }

# ── Python helpers ────────────────────────────────────────────────────────────

_require_python3() {
  if ! command -v python3 &>/dev/null; then
    die "python3 is required but not found in PATH"
  fi
}

# Read a field from a skill.json file.
# Usage: _skill_json_field <file> <field>
_skill_json_field() {
  local file="$1" field="$2"
  python3 -c "
import json, sys
try:
    d = json.load(open('${file}'))
    v = d.get('${field}')
    if v is None:
        sys.exit(0)
    if isinstance(v, list):
        print(' '.join(str(x) for x in v))
    else:
        print(v)
except Exception as e:
    sys.exit(0)
"
}

# Return "true" or "false" for a tool's supported status in a skill.json.
# Usage: _skill_supports_tool <skill_json> <tool_key>
_skill_supports_tool() {
  local file="$1" tool="$2"
  python3 -c "
import json, sys
try:
    d = json.load(open('${file}'))
    compat = d.get('compatibility', {})
    entry = compat.get('${tool}', {})
    print('true' if entry.get('supported', False) else 'false')
except Exception:
    print('false')
"
}

# ── Skill discovery ───────────────────────────────────────────────────────────

# List all skill directories: those with skill.json OR SKILL.md.
# Supports three layouts:
#   skills/<name>/                  → bundled/npm skill (1 level)
#   skills-external/<name>/         → single external skill (1 level, has SKILL.md)
#   skills-external/<pack>/<name>/  → skill pack member (2 levels, has SKILL.md)
_discover_skills() {
  # Bundled skills (1 level deep)
  if [[ -d "$SKILLS_DIR" ]]; then
    for sub in "${SKILLS_DIR}"/*/; do
      [[ -d "$sub" ]] || continue
      if [[ -f "${sub}/skill.json" || -f "${sub}/SKILL.md" ]]; then
        echo "${sub%/}"
      fi
    done
  fi

  # External skills: single skills (1 level) OR packs (2 levels)
  if [[ -d "$SKILLS_EXTERNAL_DIR" ]]; then
    for entry in "${SKILLS_EXTERNAL_DIR}"/*/; do
      [[ -d "$entry" ]] || continue
      if [[ -f "${entry}/skill.json" || -f "${entry}/SKILL.md" ]]; then
        # Single skill directly in skills-external/
        echo "${entry%/}"
      else
        # Skill pack: scan one level deeper
        for sub in "${entry}"/*/; do
          [[ -d "$sub" ]] || continue
          if [[ -f "${sub}/skill.json" || -f "${sub}/SKILL.md" ]]; then
            echo "${sub%/}"
          fi
        done
      fi
    done
  fi
}

# Return 0 if skill should be synced/checked, 1 if disabled in registry.
# Unlisted skills are allowed. Missing registry file allows all.
_registry_sync_allowed() {
  local name="$1"
  [[ ! -f "$REGISTRY_FILE" ]] && return 0
  # Line-based parse (no PyYAML): skills list uses "  - name:" and "    enabled:"
  python3 -c "
import sys
path, name_want = sys.argv[1], sys.argv[2]
current = None
current_enabled = True
try:
    for line in open(path, encoding='utf-8', errors='replace'):
        s = line.strip()
        if s.startswith('- name:'):
            if current == name_want and not current_enabled:
                sys.exit(2)
            current = s.split(':', 1)[1].strip()
            current_enabled = True
        elif current and s.startswith('enabled:'):
            v = s.split(':', 1)[1].strip().lower()
            current_enabled = v == 'true'
    if current == name_want and not current_enabled:
        sys.exit(2)
except Exception:
    sys.exit(0)
sys.exit(0)
" "$REGISTRY_FILE" "$name" 2>/dev/null
  local ec=$?
  [[ $ec -eq 2 ]] && return 1
  return 0
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_list() {
  _require_python3

  local tool_keys
  tool_keys=("${!TOOL_DIRS[@]}")

  # Header
  printf '\n%b%-22s %-10s %-10s' "$c_bold" "NAME" "SOURCE" "VERSION"
  for tool in "${tool_keys[@]}"; do
    printf ' %-14s' "$tool"
  done
  printf '%b\n' "$c_reset"
  printf '%-22s %-10s %-10s' "----" "------" "-------"
  for tool in "${tool_keys[@]}"; do printf ' %-14s' "--------------"; done
  printf '\n'

  local found=0
  while IFS= read -r skill_dir; do
    local manifest="${skill_dir}/skill.json"
    found=1

    local name source version
    if [[ -f "$manifest" ]]; then
      name="$(_skill_json_field "$manifest" name)"
      source="$(_skill_json_field "$manifest" source)"
      version="$(_skill_json_field "$manifest" version)"
    else
      name="$(basename "$skill_dir")"
      source="external"
      version="?"
    fi

    printf '%-22s %-10s %-10s' "${name:-?}" "${source:-?}" "${version:-?}"

    for tool in "${tool_keys[@]}"; do
      local link_dir="${TOOL_DIRS[$tool]}"
      local link="${link_dir}/${name}"
      local supported="true"
      [[ -f "$manifest" ]] && supported="$(_skill_supports_tool "$manifest" "$tool")"

      if [[ "$supported" == "true" ]]; then
        if [[ -L "$link" ]]; then
          printf ' %b%-14s%b' "$c_green" "✓ linked" "$c_reset"
        elif [[ -d "$link" ]]; then
          printf ' %b%-14s%b' "$c_yellow" "! dir" "$c_reset"
        else
          printf ' %b%-14s%b' "$c_yellow" "! missing" "$c_reset"
        fi
      else
        printf ' %b%-14s%b' "$c_dim" "- n/a" "$c_reset"
      fi
    done
    printf '\n'
  done < <(_discover_skills)

  if [[ $found -eq 0 ]]; then
    warn "No skills found in ${SKILLS_DIR} or ${SKILLS_EXTERNAL_DIR}"
    warn "Run 'chezmoi apply' to install bundled skills, or 'dots-skills install <name>' for npm skills."
  fi
}

cmd_sync() {
  _require_python3
  info "syncing skills to all AI tool directories..."

  local synced=0 skipped=0

  while IFS= read -r skill_dir; do
    local manifest="${skill_dir}/skill.json"
    local name
    name="$(basename "$skill_dir")"
    [[ -f "$manifest" ]] && name="$(_skill_json_field "$manifest" name)"
    [[ -z "$name" ]] && name="$(basename "$skill_dir")"

    if ! _registry_sync_allowed "$name"; then
      for tool in "${!TOOL_DIRS[@]}"; do
        local tool_dir="${TOOL_DIRS[$tool]}"
        local link="${tool_dir}/${name}"
        if [[ -L "$link" && "$(readlink "$link")" == "$skill_dir" ]]; then
          rm "$link"
          warn "registry disabled — removed link: ${link}"
        fi
      done
      continue
    fi

    for tool in "${!TOOL_DIRS[@]}"; do
      local tool_dir="${TOOL_DIRS[$tool]}"
      local supported="true"
      # If skill.json exists, respect its compatibility matrix.
      # If not (e.g. externally sourced via chezmoiexternal), assume universal support.
      [[ -f "$manifest" ]] && supported="$(_skill_supports_tool "$manifest" "$tool")"
      local link="${tool_dir}/${name}"

      if [[ "$supported" == "true" ]]; then
        mkdir -p "$tool_dir"
        if [[ -L "$link" && "$(readlink "$link")" == "$skill_dir" ]]; then
          skipped=$((skipped + 1))
          continue
        fi
        [[ -L "$link" ]] && rm "$link"
        ln -s "$skill_dir" "$link"
        ok "${name} → ${tool} (${link})"
        synced=$((synced + 1))
      else
        # Remove stale symlinks for tools that lost support
        if [[ -L "$link" ]]; then
          rm "$link"
          warn "removed stale link: ${link}"
        fi
      fi
    done
  done < <(_discover_skills)

  info "done: ${synced} link(s) created, ${skipped} already up to date"
}

cmd_check() {
  _require_python3
  info "checking skill requirements..."

  local errors=0

  while IFS= read -r skill_dir; do
    local manifest="${skill_dir}/skill.json"
    [[ -f "$manifest" ]] || continue

    local name
    name="$(_skill_json_field "$manifest" name)"
    [[ -z "$name" ]] && name="$(basename "$skill_dir")"
    if ! _registry_sync_allowed "$name"; then
      continue
    fi

    # Read requires array
    local requires
    requires="$(python3 -c "
import json
d = json.load(open('${manifest}'))
print('\n'.join(d.get('requires', [])))
" 2>/dev/null)"

    # Read pip_packages array
    local pip_pkgs
    pip_pkgs="$(python3 -c "
import json, subprocess
d = json.load(open('${manifest}'))
print('\n'.join(d.get('pip_packages', [])))
" 2>/dev/null)"

    if [[ -z "$requires" && -z "$pip_pkgs" ]]; then
      ok "${name}: no requirements"
      continue
    fi

    local skill_ok=true
    while IFS= read -r cmd; do
      [[ -z "$cmd" ]] && continue
      if command -v "$cmd" &>/dev/null; then
        ok "${name}: '${cmd}' found"
      else
        fail "${name}: '${cmd}' not found in PATH"
        skill_ok=false
        errors=$((errors + 1))
      fi
    done <<< "$requires"

    # Check pip_packages via uv tool list / pipx list
    while IFS= read -r pkg; do
      [[ -z "$pkg" ]] && continue
      local pip_name="${pkg%%[>=<!]*}"  # strip version specifiers
      local installed=false
      if command -v uv &>/dev/null; then
        uv tool list 2>/dev/null | grep -q "$pip_name" && installed=true
      fi
      if [[ "$installed" == false ]] && command -v pipx &>/dev/null; then
        pipx list --short 2>/dev/null | grep -q "^${pip_name} " && installed=true
      fi
      if [[ "$installed" == true ]]; then
        ok "${name}: '${pip_name}' installed"
      else
        if command -v uv &>/dev/null; then
          fail "${name}: '${pip_name}' not installed (run: uv tool install ${pkg})"
        else
          fail "${name}: '${pip_name}' not installed (run: pipx install ${pkg})"
        fi
        skill_ok=false
        errors=$((errors + 1))
      fi
    done <<< "$pip_pkgs"
  done < <(_discover_skills)

  if [[ $errors -gt 0 ]]; then
    warn "${errors} missing tool(s) detected. Install them and re-run 'dots-skills check'."
    return 1
  fi
  info "all skill requirements satisfied"
}

cmd_install() {
  _require_python3
  local name="${1:-}"
  [[ -z "$name" ]] && die "Usage: dots-skills install <skill-name>"

  if [[ ! -f "$REGISTRY_FILE" ]]; then
    die "Registry not found at ${REGISTRY_FILE}. Run 'chezmoi apply' first."
  fi

  # Find the skill entry in the registry
  local entry
  entry="$(python3 -c "
import sys
try:
    import yaml
except ImportError:
    print('NOYAML')
    sys.exit(0)
import json
with open('${REGISTRY_FILE}') as f:
    data = yaml.safe_load(f)
for skill in data.get('skills', []):
    if skill.get('name') == '${name}':
        print(json.dumps(skill))
        sys.exit(0)
print('NOTFOUND')
" 2>/dev/null)"

  # Fallback: try without PyYAML using grep
  if [[ "$entry" == "NOYAML" ]]; then
    warn "PyYAML not available — falling back to basic registry parsing"
    entry="$(python3 -c "
import sys, re, json
# Very basic YAML list-of-dicts parser (no nested objects)
with open('${REGISTRY_FILE}') as f:
    content = f.read()
blocks = re.split(r'\n  - ', content)
for block in blocks:
    lines = block.strip().splitlines()
    d = {}
    for line in lines:
        m = re.match(r'^\s*(\w+):\s*(.*)', line)
        if m:
            k, v = m.group(1), m.group(2).strip().strip('\"')
            d[k] = v
    if d.get('name') == '${name}':
        print(json.dumps(d))
        sys.exit(0)
print('NOTFOUND')
" 2>/dev/null)"
  fi

  [[ "$entry" == "NOTFOUND" || -z "$entry" ]] && die "Skill '${name}' not found in registry. Run 'dots-skills list' to see available skills."

  local source package
  source="$(echo "$entry" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('source',''))")"
  local skill_dir="${SKILLS_EXTERNAL_DIR}/${name}"

  case "$source" in
    bundled)
      info "'${name}' is a bundled skill — it is installed via chezmoi apply"
      info "Run 'chezmoi apply' to ensure it is up to date"
      return 0
      ;;
    npm)
      package="$(echo "$entry" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('package',''))")"
      [[ -z "$package" ]] && die "Registry entry for '${name}' has no 'package' field"
      info "installing npm package: ${package}"
      npm install -g "$package"
      local npm_prefix
      npm_prefix="$(npm root -g 2>/dev/null || echo "")"
      if [[ -n "$npm_prefix" && -d "${npm_prefix}/${package}" ]]; then
        mkdir -p "$SKILLS_EXTERNAL_DIR"
        [[ -L "$skill_dir" ]] && rm "$skill_dir"
        ln -sfn "${npm_prefix}/${package}" "$skill_dir"
        ok "linked ${skill_dir} → ${npm_prefix}/${package}"
      else
        warn "Could not locate npm package directory — symlink not created"
        warn "Run 'dots-skills sync' manually after verifying the package path"
      fi
      ;;
    github|url)
      info "'${name}' source '${source}' is managed by chezmoi (.chezmoiexternal)."
      info "Enable it in chezmoi config, then run: chezmoi apply"
      info "See: https://www.chezmoi.io/reference/special-files/chezmoiexternal-format/"
      return 0
      ;;
    *)
      die "Unknown source '${source}' for skill '${name}'"
      ;;
  esac

  info "running sync to create symlinks..."
  cmd_sync
}

cmd_add() {
  local source_spec="${1:-}"
  [[ -z "$source_spec" ]] && die "Usage: dots-skills add npm:<pkg> | github:<owner/repo> | url:<url>"

  if [[ ! -f "$REGISTRY_FILE" ]]; then
    die "Registry not found at ${REGISTRY_FILE}. Run 'chezmoi apply' first."
  fi

  local type="${source_spec%%:*}"
  local value="${source_spec#*:}"

  case "$type" in
    npm)
      local name="${value##*/}"
      name="${name//@/}"   # strip @ scope prefix
      info "adding npm skill '${name}' (package: ${value}) to registry..."
      python3 -c "
import re, sys
with open('${REGISTRY_FILE}') as f:
    content = f.read()
entry = '''
  - name: ${name}
    source: npm
    package: ${value}
    enabled: true
'''
# Append before the first commented example block or at end of skills list
content = content.rstrip()
with open('${REGISTRY_FILE}', 'w') as f:
    f.write(content + entry + '\n')
print('added')
"
      ok "added '${name}' to registry — run 'dots-skills install ${name}' to install"
      ;;
    github)
      local name="${value##*/}"
      info "adding github skill '${name}' (repo: ${value}) to registry..."
      python3 -c "
with open('${REGISTRY_FILE}') as f:
    content = f.read()
entry = '''
  - name: ${name}
    source: github
    repo: ${value}
    ref: main
    enabled: true
'''
content = content.rstrip()
with open('${REGISTRY_FILE}', 'w') as f:
    f.write(content + entry + '\n')
"
      ok "added '${name}' to registry — run 'dots-skills install ${name}' to install"
      ;;
    url)
      local name
      name="$(basename "$value" .tar.gz)"
      info "adding url skill '${name}' to registry..."
      python3 -c "
with open('${REGISTRY_FILE}') as f:
    content = f.read()
entry = '''
  - name: ${name}
    source: url
    url: ${value}
    enabled: true
'''
content = content.rstrip()
with open('${REGISTRY_FILE}', 'w') as f:
    f.write(content + entry + '\n')
"
      ok "added '${name}' to registry — run 'dots-skills install ${name}' to install"
      ;;
    *)
      die "Unknown source type '${type}'. Use npm:, github:, or url:"
      ;;
  esac
}

# ── Main ──────────────────────────────────────────────────────────────────────

command="${1:-}"
shift || true

case "$command" in
  list)    cmd_list ;;
  sync)    cmd_sync ;;
  install) cmd_install "${1:-}" ;;
  check)   cmd_check ;;
  add)     cmd_add "${1:-}" ;;
  ""|--help|-h)
    # easyoptions handles --help via the header comment block
    ;;
  *)
    die "Unknown command '${command}'. Run 'dots-skills --help' for usage."
    ;;
esac
