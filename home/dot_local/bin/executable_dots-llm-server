#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LLM_SERVER_LIB="$HOME/.local/lib/dots-ai/llm-server.sh"
if [[ ! -f "$LLM_SERVER_LIB" ]]; then
  echo "Missing: $LLM_SERVER_LIB" >&2
  exit 1
fi
source "$LLM_SERVER_LIB"
command="${1:-}"
case "$command" in
  install) llm_install ;;
  start) llm_start "${1:-}" ;;
  stop) llm_stop ;;
  status) llm_status ;;
  logs) llm_logs ;;
  switch) llm_switch "${2:-}" ;;
  restart) llm_stop; llm_start ;;
  *) echo "Unknown: $command"; exit 1 ;;
esac
