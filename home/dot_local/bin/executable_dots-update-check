#!/usr/bin/env bash
set -eo pipefail

## nan-update-check
##
## Checks if your local baseline branch is behind origin.
##
## Usage:
##     @script.name [option]
##
## Options:
##     -h, --help              Show this help message.
##         --remote=NAME       Remote to check (default: origin).
##         --branch=NAME       Branch to check (default: current branch).
##
SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_DOTS_AI_LIB_DIR="$(cd -- "${SCRIPT_DIR}/../lib/dots-ai" 2>/dev/null && pwd || true)"
DOTS_AI_LIB_DIR="${DOTS_AI_LIB_DIR:-${DEFAULT_DOTS_AI_LIB_DIR:-$HOME/.local/lib/dots-ai}}"
EASY_OPTIONS_LIB="${DOTS_AI_LIB_DIR}/easy-options/easyoptions.sh"
NO_CHECK=1
options=(h=help)

if [[ ! -f "${EASY_OPTIONS_LIB}" ]]; then
  echo "[nan-update-check] Missing dependency: ${EASY_OPTIONS_LIB}" >&2
  exit 1
fi
source "${EASY_OPTIONS_LIB}"

if [[ -t 1 && -z ${NO_COLOR:-} ]]; then
  c_reset=$'\033[0m'
  c_blue=$'\033[1;34m'
  c_red=$'\033[1;31m'
  c_green=$'\033[1;32m'
  c_yellow=$'\033[1;33m'
else
  c_reset=''
  c_blue=''
  c_red=''
  c_green=''
  c_yellow=''
fi

info() { printf '%b[nan-update-check]%b %s\n' "$c_blue" "$c_reset" "$*"; }
fail() { printf '%b[nan-update-check]%b %s\n' "$c_red" "$c_reset" "$*"; }
ok() { printf '%b[nan-update-check]%b %s\n' "$c_green" "$c_reset" "$*"; }
warn() { printf '%b[nan-update-check]%b %s\n' "$c_yellow" "$c_reset" "$*"; }

if ! command -v git >/dev/null 2>&1; then
  fail "git is required for update checks" >&2
  exit 1
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  fail "Run this command inside your chezmoi source repository checkout."
  exit 1
fi

remote_name="origin"
current_branch="$(git rev-parse --abbrev-ref HEAD)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --remote=*)
      remote_name="${1#*=}"
      shift
      ;;
    --remote)
      if [[ $# -lt 2 || "$2" == -* ]]; then
        fail "you must specify a value for --remote"
        exit 1
      fi
      remote_name="$2"
      shift 2
      ;;
    --branch=*)
      current_branch="${1#*=}"
      shift
      ;;
    --branch)
      if [[ $# -lt 2 || "$2" == -* ]]; then
        fail "you must specify a value for --branch"
        exit 1
      fi
      current_branch="$2"
      shift 2
      ;;
    --help|-h)
      # Already handled by easy-options.
      shift
      ;;
    *)
      fail "unrecognized option: $1"
      echo "See --help for usage and options." >&2
      exit 1
      ;;
  esac
done

info "checking updates for ${remote_name}/${current_branch}"
git fetch --quiet "${remote_name}" "${current_branch}"

local_sha="$(git rev-parse HEAD)"
remote_sha="$(git rev-parse "${remote_name}/${current_branch}")"

if [[ "${local_sha}" != "${remote_sha}" ]]; then
  warn "A newer baseline version is available. Please run: chezmoi update"
  exit 0
fi

ok "Your baseline appears up to date."
