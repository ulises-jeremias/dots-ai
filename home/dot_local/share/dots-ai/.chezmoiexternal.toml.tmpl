# chezmoi:template:left-delimiter="{{" right-delimiter="}}"
#
# External skills managed natively by chezmoi.
# Entries are relative to ~/.local/share/dots-ai/
#
# Chezmoi handles download, extraction, caching, and refresh automatically.
# After chezmoi apply, run `dots-skills sync` to create AI tool symlinks.
#
# To refresh cached archives: chezmoi apply --refresh-externals
#
# ── JIRA Assistant Skills (skill pack — 14 JIRA skills) ─────────────────────
# Requires env vars: JIRA_API_TOKEN, JIRA_EMAIL, JIRA_SITE_URL
# Enable via: chezmoi edit-config → install_skill_jira_assistant = true
{{- if (index . "install_skill_jira_assistant" | default false) }}
# Skill pack: each subdirectory under skills/ becomes a separate skill.
# Key "skills-external/jira-assistant" → ~/.local/share/dots-ai/skills-external/jira-assistant/
# stripComponents=2 strips "JIRA-Assistant-Skills-main/" and "skills/" so
# "JIRA-Assistant-Skills-main/skills/jira-admin/SKILL.md" → "jira-admin/SKILL.md"
["skills-external/jira-assistant"]
    type            = "archive"
    url             = "https://github.com/ulises-jeremias/JIRA-Assistant-Skills/archive/refs/heads/main.tar.gz"
    stripComponents = 2
    include         = ["*/skills/**"]
    refreshPeriod   = "168h"
{{- end }}

# ── Confluence Assistant Skills (skill pack — 17 Confluence skills) ─────────
# Requires env vars: CONFLUENCE_API_TOKEN, CONFLUENCE_EMAIL, CONFLUENCE_SITE_URL
# Enable via: chezmoi edit-config → install_skill_confluence_assistant = true
{{- if (index . "install_skill_confluence_assistant" | default false) }}
# Skill pack: each subdirectory under skills/ becomes a separate skill.
# Key "skills-external/confluence-assistant" → ~/.local/share/dots-ai/skills-external/confluence-assistant/
# stripComponents=2 strips "Confluence-Assistant-Skills-main/" and "skills/" so
# "Confluence-Assistant-Skills-main/skills/confluence-page/SKILL.md" → "confluence-page/SKILL.md"
["skills-external/confluence-assistant"]
    type            = "archive"
    url             = "https://github.com/ulises-jeremias/Confluence-Assistant-Skills/archive/refs/heads/main.tar.gz"
    stripComponents = 2
    include         = ["*/skills/**"]
    refreshPeriod   = "168h"
{{- end }}

