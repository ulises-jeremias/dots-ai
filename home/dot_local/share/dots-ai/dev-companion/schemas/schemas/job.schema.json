{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dots-ai Dev Companion Job",
  "type": "object",
  "required": ["id", "created_at", "request"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "request": { "type": "string", "minLength": 1 },
    "account": { "type": "string" },
    "team": { "type": "string" },
    "repo_path": { "type": "string" },
    "ticket_key": { "type": "string" },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_sec": { "type": "integer", "minimum": 1, "default": 1800 },
        "max_steps": { "type": "integer", "minimum": 1, "default": 25 },
        "max_cost_usd": { "type": "number", "minimum": 0 }
      }
    },
    "actions_allowed": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["plan_only", "edit_files", "git_commit", "git_push", "draft_pr", "ticket_comment"]
      },
      "uniqueItems": true
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "command": { "type": "array", "items": { "type": "string" } },
        "timeout_sec": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
