{
  "$schema": "https://raw.githubusercontent.com/ulises-jeremias/dots-ai/main/lib/schemas/skill.schema.json",
  "name": "playwright-cli",
  "version": "1.0.0",
  "description": "Drive a real browser from the terminal using the Playwright CLI (snapshot, click, fill, screenshots, traces). Use for CLI-first browser automation; for Playwright test specs use dots-ai-e2e-runner.",
  "source": "bundled",
  "author": "dots-ai",
  "tags": [
    "playwright",
    "browser",
    "cli",
    "automation"
  ],
  "requires": [
    "npx"
  ],
  "compatibility": {
    "universal": {
      "supported": true
    },
    "claude-code": {
      "supported": true
    },
    "cursor": {
      "supported": true
    },
    "opencode": {
      "supported": true
    },
    "windsurf": {
      "supported": true
    },
    "pi": {
      "supported": true
    }
  }
}
