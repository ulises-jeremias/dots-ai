  "author": "dots-ai",
  "tags": [
    "github",
    "pull-request",
    "code-review"
  ],
  "requires": [
    "gh",
    "python3"
  ],
  "compatibility": {
    "universal": {
      "supported": true
    },
    "claude-code": {
      "supported": true
    },
    "cursor": {
      "supported": true
    },
    "opencode": {
      "supported": true
    },
    "windsurf": {
      "supported": true
    },
    "pi": {
      "supported": true
    }
  }
}
