    "mcp",
    "code-connect",
    "design-system"
  ],
  "requires": [
    "python3"
  ],
  "compatibility": {
    "universal": {
      "supported": true
    },
    "claude-code": {
      "supported": true
    },
    "cursor": {
      "supported": true
    },
    "opencode": {
      "supported": true
    },
    "windsurf": {
      "supported": true
    },
    "pi": {
      "supported": true
    }
  }
}
